# =============================================================================
# Sentinel AI - Environment Configuration
# =============================================================================
# Copy this file to `.env` and fill in your values before running the project.
#   cp .env.example .env
#
# The system automatically selects an LLM backend in this priority order:
#   1. NVIDIA NIM  (if NVIDIA_API_KEY is set)
#   2. Local Ollama (if running on localhost:11434)
#   3. Simulation mode (hardcoded fallback responses - no model required)
# =============================================================================


# -----------------------------------------------------------------------------
# OPTION 1: NVIDIA NIM (Recommended for recruiters / evaluators)
# -----------------------------------------------------------------------------
# Free API key available at: https://build.nvidia.com
# Model used: meta/llama-3.1-8b-instruct (lightweight, powerful)
# -----------------------------------------------------------------------------
NVIDIA_API_KEY=YOUR_NVIDIA_NIM_API_KEY_HERE

# Model to use via NVIDIA NIM (choose one):
#   qwen/qwen2.5-coder-7b-instruct   ← Recommended (code-optimized, fast)
#   meta/llama-3.1-8b-instruct        ← General reasoning
#   nvidia/nemotron-mini-4b-instruct  ← Fastest / most lightweight
#   mistralai/codestral-22b-v0-1      ← Best code quality, slower
NVIDIA_NIM_MODEL=qwen/qwen2.5-coder-7b-instruct


# -----------------------------------------------------------------------------
# OPTION 2: Local Ollama (No API key required)
# -----------------------------------------------------------------------------
# Install Ollama from https://ollama.com, then run:
#   ollama pull qwen2.5-coder
# The system detects it automatically. Leave NVIDIA_API_KEY blank to use this.
# OLLAMA_BASE_URL is optional — defaults to http://localhost:11434/v1
# -----------------------------------------------------------------------------
# OLLAMA_BASE_URL=http://localhost:11434/v1
# OLLAMA_MODEL=qwen2.5-coder


# -----------------------------------------------------------------------------
# GitHub Integration (Optional - for automated bug filing)
# -----------------------------------------------------------------------------
# Required only for the auto bug-creation feature in the Decision Engine.
# Generate a token at: https://github.com/settings/tokens
# -----------------------------------------------------------------------------
GITHUB_TOKEN=YOUR_GITHUB_PERSONAL_ACCESS_TOKEN_HERE
GITHUB_REPO=your-username/your-repo-name


# -----------------------------------------------------------------------------
# Redis (Required for Celery background workers)
# -----------------------------------------------------------------------------
# Defaults to localhost if not set. Docker Compose sets this automatically.
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0
